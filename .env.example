# API Keys — copy to .env and fill in your values
# NEVER commit the real .env file to version control.

# Required for answer generation
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: set to "true" to use OpenAI embeddings instead of HuggingFace
# (also set USE_OPENAI_EMBEDDINGS = True in config.py)
# OPENAI_EMBEDDING_ENABLED=false
